# User ID and Group ID for the container user
PUID=1000
PGID=1000

# Komodo daemon RPC URL
DAEMON_URL=http://rpcuser:rpcpassword@127.0.0.1:7771/

# SSL Certificate Configuration (for certbot)
DOMAIN_NAME=example.com
CF_API_TOKEN=your_cloudflare_api_token_here
CF_EMAIL=admin@example.com

# SSL Certificate paths (set these based on your DOMAIN_NAME)
# Example: if DOMAIN_NAME=example.com, then:
SSL_CERTFILE=/ssl/example.com/fullchain.pem
SSL_KEYFILE=/ssl/example.com/privkey.pem

# Certificate renewal check interval in seconds (default: 86400 = 24 hours)
RENEWAL_INTERVAL=86400
